# Required: Streamtape credentials (for uploads to streamtape.com)
STREAMTAPE_LOGIN=your_streamtape_login_email
STREAMTAPE_API_KEY=your_streamtape_api_key

# Required: VoeSX API key (for uploads to voe.sx)
VOESX_API_KEY=your_voesx_api_key

# Required: SendCM API key (for uploads to send.cm)
SENDCM_API_KEY=your_sendcm_api_key

# Optional: GoFile API key (for authenticated uploads to gofile.io).
# If omitted, uploads as guest (files expire after some time).
GOFILE_API_KEY=your_gofile_api_token

# Optional: Byse API key (for uploads to byse.sx).
# Get it from https://byse.sx/api while logged in.
BYSE_API_KEY=your_byse_api_key

# Required for GitHub Actions: Supabase configuration
# Used for tunnel tracking
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_API_KEY=your_supabase_anon_key
